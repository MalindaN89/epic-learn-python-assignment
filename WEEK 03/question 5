def divide_numbers():
    try:
        num1 = float(input("Enter num 1:"))
        num2 = float(input("Enter num 2:"))

        result = num1/num2
        print("Result of num1 divided num2:", result)

    except ZeroDivisionError:
      print("Error:Division by zero, cannot divide by Zero ")
    except ValueError:
      print("Error:Pls enter valid number ")
divide_numbers()
